<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TraceIt" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/md_primary</item>
        <item name="android:windowBackground">@color/md_background</item>
    </style>

    <style name="TextAppearance.LostFound.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Theme.TraceIt" parent="Base.Theme.TraceIt" />
</resources>